npm run lint && npm run type-check && npm run format:check

# ── Lockfile ↔ package.json version match ──
# Catch the class of bug where package.json is bumped but the lockfile's
# top-level `version` field is forgotten, so `npm ci` on a clean clone
# reproduces the pre-bump tree. Surfaced from issue #52 on 2026-04-22.
if [ -f package-lock.json ]; then
  node -e 'const p=require("./package.json"); const l=require("./package-lock.json"); if (p.version !== l.version) { console.error("\n  ERROR: package-lock.json version ("+l.version+") does not match package.json ("+p.version+")."); console.error("  Fix: npm install --package-lock-only && git add package-lock.json\n"); process.exit(1); }' || exit 1
fi

# ── Skip CHANGELOG/version checks on merge commits ──
# Merge commits consolidate existing history; they don't introduce new
# changelog entries of their own. Blocking them forces empty edits that
# don't add value. Quality checks above still run on every commit.
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || echo ".git")
if [ -f "$GIT_DIR/MERGE_HEAD" ]; then
  exit 0
fi

# ── Require CHANGELOG.md to be updated ──
# Check if CHANGELOG.md is staged or was recently modified
BRANCH=$(git branch --show-current 2>/dev/null || echo "")

if [ "$BRANCH" = "dev" ] || [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  # On protected branches: block if CHANGELOG.md is not staged
  if ! git diff --cached --name-only | grep -q "^CHANGELOG.md$"; then
    echo ""
    echo "  ERROR: CHANGELOG.md must be updated when committing to '$BRANCH'."
    echo "  Add your changes to CHANGELOG.md under the [Unreleased] section,"
    echo "  then stage it: git add CHANGELOG.md"
    echo ""
    exit 1
  fi
fi

# ── On master: require version bump ──
if [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  if ! git diff --cached --name-only | grep -q "^package.json$"; then
    echo ""
    echo "  ERROR: package.json must be updated (version bump) when committing to '$BRANCH'."
    echo "  Bump the version in package.json and stage it: git add package.json"
    echo ""
    exit 1
  fi
fi
